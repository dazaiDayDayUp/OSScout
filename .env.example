# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/osscout

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM（Kimi + DeepSeek）===
# Kimi (Moonshot AI): https://platform.moonshot.cn/
KIMI_API_KEY=sk-...
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# 默认使用的 Provider: kimi | deepseek
DEFAULT_LLM_PROVIDER=kimi
DEFAULT_LLM_MODEL=

# === GitHub ===
GITHUB_TOKEN=ghp_...

# === Phase 4.6: Web 搜索 Fallback（可选）===
# Serper API: https://serper.dev/ 每月 2500 次免费查询
# 不配置时 Self-RAG 仍可用，只是无法 fallback 到 Web 搜索
SERPER_API_KEY=

# === 应用 ===
DEBUG=false
LOG_LEVEL=INFO
ANALYSIS_TIMEOUT=300
