# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/osscout

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === LLM（Kimi + DeepSeek）===
# Kimi (Moonshot AI): https://platform.moonshot.cn/
KIMI_API_KEY=sk-...
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# 默认使用的 Provider: kimi | deepseek
DEFAULT_LLM_PROVIDER=kimi
DEFAULT_LLM_MODEL=

# === GitHub ===
GITHUB_TOKEN=ghp_...

# === Phase 4.6: Web 搜索 Fallback（可选）===
# Serper API: https://serper.dev/ 每月 2500 次免费查询
# 不配置时 Self-RAG 仍可用，只是无法 fallback 到 Web 搜索
SERPER_API_KEY=

# === 邮件推送配置（FastAPI-Mail + QQ 邮箱 SMTP）===
# QQ 邮箱 SMTP 设置：
#   SMTP 服务器：smtp.qq.com
#   端口：465（SSL）
#   密码：不是登录密码，而是「授权码」
#   获取方式：登录 QQ 邮箱网页版 → 设置 → 账户 → 开启「IMAP/SMTP服务」→ 获取 16 位授权码
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
MAIL_USE_CREDENTIALS=true
MAIL_VALIDATE_CERTS=true

# === 应用 ===
DEBUG=false
LOG_LEVEL=INFO
ANALYSIS_TIMEOUT=300
